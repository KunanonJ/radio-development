{
  "name": "radioboss-cloudflare-suite",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "containers/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:console": "npm run dev --workspace @radioboss/console",
    "dev:admin": "npm run dev --workspace @radioboss/admin",
    "dev:public": "npm run dev --workspace @radioboss/public",
    "dev:api": "npm run dev --workspace @radioboss/control-api",
    "dev:gateway": "npm run dev --workspace @radioboss/station-gateway",
    "dev:playout": "npm run start --workspace @radioboss/playout-container",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:locales": "python3 scripts/validate_locales.py",
    "provision": "node scripts/provision-station.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@cloudflare/containers": "latest",
    "@cloudflare/vite-plugin": "latest",
    "@cloudflare/workers-types": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-rsc": "latest",
    "next": "^16.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vinext": "latest",
    "vitest": "latest",
    "wrangler": "latest"
  }
}
